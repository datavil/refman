{
  "manifest_version": 3,
  "name": "Refman",
  "description": "Save research articles and PDFs to your local Refman library.",
  "version": "0.11.1",
  "permissions": ["activeTab", "contextMenus", "scripting", "storage"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "host_permissions": ["http://127.0.0.1:23119/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Save to Refman",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
